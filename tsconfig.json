{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["api-utils/*"],
      "@fixtures/*": ["fixtures/*"],
      "@pages/*": ["page-objects/*"],
      "@test-data/*": ["test-data/*"]
    }
  },
  "include": ["**/*.ts"]
}